{
  "$schema": "http://json.schemastore.org/template",
  "author": "Josh J Piluden",
  "classifications": [
    "Config",
    "Repository"
  ],
  "name": "My Template Configs",
  "description": "Adds my standard repository configuration files.",
  "identity": "my-templates.repo-configs",
  "groupIdentity": "my-templates.repo-configs",
  "shortName": "configs",
  "defaultName": "MyConfigs",
  "tags": {
    "type": "item"
  },
  "preferNameDirectory": false,
  "primaryOutputs": [
    {
      "path": "./.editorconfig"
    },
    {
      "path": "./.gitignore"
    }
  ],
  "sources": [
    {
      "source": "../.template.base/configs",
      "target": "./"
    }
  ]
}
